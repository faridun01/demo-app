generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                    @id @default(autoincrement())
  username             String                 @unique
  passwordHash         String                 @map("password_hash")
  phone                String?
  role                 String                 @default("SELLER")
  warehouseId          Int?                   @map("warehouse_id")
  active               Boolean                @default(true)
  canCancelInvoices    Boolean                @default(false) @map("can_cancel_invoices")
  canDeleteData        Boolean                @default(false) @map("can_delete_data")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  twoFactorBackupCodes String[]               @default([]) @map("two_factor_backup_codes")
  twoFactorEnabled     Boolean                @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?                @map("two_factor_secret")
  expenses             Expense[]
  transactions         InventoryTransaction[]
  invoices             Invoice[]
  payments             Payment[]
  reminders            Reminder[]
  returns              Return[]
  warehouse            Warehouse?             @relation(fields: [warehouseId], references: [id])

  @@map("users")
}

model Warehouse {
  id                Int                    @id @default(autoincrement())
  name              String
  address           String?
  city              String?
  note              String?
  active            Boolean                @default(true)
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  phone             String?
  isDefault         Boolean                @default(false) @map("is_default")
  expenses          Expense[]
  transactions      InventoryTransaction[]
  invoices          Invoice[]
  batches           ProductBatch[]
  packagings        ProductPackaging[]
  products          Product[]
  purchaseDocuments PurchaseDocument[]
  users             User[]

  @@map("warehouses")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("categories")
}

model Product {
  id                Int                    @id @default(autoincrement())
  categoryId        Int                    @map("category_id")
  sku               String?
  name              String
  unit              String
  costPrice         Decimal                @map("cost_price") @db.Decimal(12, 2)
  sellingPrice      Decimal                @map("selling_price") @db.Decimal(12, 2)
  minStock          Float                  @default(0) @map("min_stock")
  initialStock      Float                  @default(0) @map("initial_stock")
  totalIncoming     Float                  @default(0) @map("total_incoming")
  stock             Float                  @default(0)
  photoUrl          String?                @map("photo_url")
  active            Boolean                @default(true)
  warehouseId       Int?                   @map("warehouse_id")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  baseUnitName      String                 @default("шт") @map("base_unit_name")
  brand             String?
  expensePercent    Float                  @default(0) @map("expense_percent")
  nameKey           String                 @default("") @map("name_key")
  purchaseCostPrice Decimal?               @map("purchase_cost_price") @db.Decimal(12, 2)
  rawName           String?                @map("raw_name")
  transactions      InventoryTransaction[]
  invoiceItems      InvoiceItem[]
  priceHistory      PriceHistory[]
  batches           ProductBatch[]
  packagings        ProductPackaging[]
  category          Category               @relation(fields: [categoryId], references: [id])
  warehouse         Warehouse?             @relation(fields: [warehouseId], references: [id])
  purchaseItems     PurchaseDocumentItem[]

  @@unique([warehouseId, nameKey])
  @@unique([name, warehouseId])
  @@unique([sku, warehouseId])
  @@map("products")
}

model ProductPackaging {
  id                  Int        @id @default(autoincrement())
  productId           Int        @map("product_id")
  warehouseId         Int?       @map("warehouse_id")
  packageName         String     @map("package_name")
  baseUnitName        String     @map("base_unit_name")
  unitsPerPackage     Int        @map("units_per_package")
  packageSellingPrice Decimal?   @map("package_selling_price") @db.Decimal(12, 2)
  barcode             String?
  active              Boolean    @default(true)
  isDefault           Boolean    @default(false) @map("is_default")
  sortOrder           Int        @default(0) @map("sort_order")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  product             Product    @relation(fields: [productId], references: [id])
  warehouse           Warehouse? @relation(fields: [warehouseId], references: [id])

  @@unique([productId, packageName, unitsPerPackage])
  @@unique([barcode, warehouseId])
  @@map("product_packagings")
}

model PriceHistory {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  costPrice    Decimal  @map("cost_price") @db.Decimal(12, 2)
  sellingPrice Decimal  @map("selling_price") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  product      Product  @relation(fields: [productId], references: [id])

  @@map("price_history")
}

model ProductBatch {
  id                Int              @id @default(autoincrement())
  productId         Int              @map("product_id")
  warehouseId       Int              @map("warehouse_id")
  quantity          Float
  remainingQuantity Float            @map("remaining_quantity")
  costPrice         Decimal          @map("cost_price") @db.Decimal(12, 2)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  expensePercent    Float            @default(0) @map("expense_percent")
  purchaseCostPrice Decimal?         @map("purchase_cost_price") @db.Decimal(12, 2)
  product           Product          @relation(fields: [productId], references: [id])
  warehouse         Warehouse        @relation(fields: [warehouseId], references: [id])
  saleAllocations   SaleAllocation[]

  @@map("product_batches")
}

model Customer {
  id               Int       @id @default(autoincrement())
  name             String
  phone            String?
  address          String?
  notes            String?
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  city             String?
  createdByUserId  Int?      @map("created_by_user_id")
  companyName      String?   @map("company_name")
  contactName      String?   @map("contact_name")
  country          String?
  customerType     String    @default("individual") @map("customer_type")
  region           String?
  customerCategory String?   @map("customer_category")
  invoices         Invoice[]
  payments         Payment[]
  returns          Return[]

  @@map("customers")
}

model CompanyProfile {
  id          Int      @id @default(autoincrement())
  name        String
  country     String?
  region      String?
  city        String?
  addressLine String?  @map("address_line")
  phone       String?
  note        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("company_profiles")
}

model Supplier {
  id                Int                @id @default(autoincrement())
  name              String
  phone             String?
  address           String?
  city              String?
  notes             String?
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  purchaseDocuments PurchaseDocument[]

  @@map("suppliers")
}

model PurchaseDocument {
  id             Int                    @id @default(autoincrement())
  supplierId     Int?                   @map("supplier_id")
  warehouseId    Int                    @map("warehouse_id")
  sourceType     String                 @default("pdf") @map("source_type")
  documentNumber String?                @map("document_number")
  documentDate   DateTime?              @map("document_date")
  fileUrl        String?                @map("file_url")
  rawText        String?                @map("raw_text")
  status         String                 @default("draft")
  importedAt     DateTime?              @map("imported_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  items          PurchaseDocumentItem[]
  supplier       Supplier?              @relation(fields: [supplierId], references: [id])
  warehouse      Warehouse              @relation(fields: [warehouseId], references: [id])

  @@map("purchase_documents")
}

model PurchaseDocumentItem {
  id                            Int              @id @default(autoincrement())
  purchaseDocumentId            Int              @map("purchase_document_id")
  matchedProductId              Int?             @map("matched_product_id")
  rawName                       String           @map("raw_name")
  cleanName                     String           @map("clean_name")
  brand                         String?
  nameKey                       String           @map("name_key")
  packageName                   String?          @map("package_name")
  baseUnitName                  String           @map("base_unit_name")
  unitsPerPackage               Int?             @map("units_per_package")
  packageQuantity               Float?           @map("package_quantity")
  extraUnitQuantity             Float            @default(0) @map("extra_unit_quantity")
  totalBaseUnits                Float            @map("total_base_units")
  expensePercent                Float            @default(0) @map("expense_percent")
  costPricePerBaseUnit          Decimal?         @map("cost_price_per_base_unit") @db.Decimal(12, 2)
  effectiveCostPricePerBaseUnit Decimal?         @map("effective_cost_price_per_base_unit") @db.Decimal(12, 2)
  createdAt                     DateTime         @default(now()) @map("created_at")
  matchedProduct                Product?         @relation(fields: [matchedProductId], references: [id])
  purchaseDocument              PurchaseDocument @relation(fields: [purchaseDocumentId], references: [id])

  @@map("purchase_document_items")
}

model Invoice {
  id                      Int           @id @default(autoincrement())
  customerId              Int           @map("customer_id")
  userId                  Int           @map("user_id")
  warehouseId             Int           @map("warehouse_id")
  totalAmount             Decimal       @map("total_amount") @db.Decimal(12, 2)
  discount                Float         @default(0)
  tax                     Decimal       @default(0) @db.Decimal(12, 2)
  netAmount               Decimal       @map("net_amount") @db.Decimal(12, 2)
  paidAmount              Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  returnedAmount          Decimal       @default(0) @map("returned_amount") @db.Decimal(12, 2)
  status                  String        @default("unpaid")
  cancelled               Boolean       @default(false)
  paymentDueDate          DateTime?     @map("payment_due_date")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")
  companyAddressSnapshot  String?       @map("company_address_snapshot")
  companyCitySnapshot     String?       @map("company_city_snapshot")
  companyCountrySnapshot  String?       @map("company_country_snapshot")
  companyNameSnapshot     String?       @map("company_name_snapshot")
  companyRegionSnapshot   String?       @map("company_region_snapshot")
  customerAddressSnapshot String?       @map("customer_address_snapshot")
  customerNameSnapshot    String?       @map("customer_name_snapshot")
  customerPhoneSnapshot   String?       @map("customer_phone_snapshot")
  items                   InvoiceItem[]
  customer                Customer      @relation(fields: [customerId], references: [id])
  user                    User          @relation(fields: [userId], references: [id])
  warehouse               Warehouse     @relation(fields: [warehouseId], references: [id])
  payments                Payment[]
  returns                 Return[]

  @@map("invoices")
}

model InvoiceItem {
  id                      Int              @id @default(autoincrement())
  invoiceId               Int              @map("invoice_id")
  productId               Int              @map("product_id")
  quantity                Float
  sellingPrice            Decimal          @map("selling_price") @db.Decimal(12, 2)
  costPrice               Decimal          @default(0) @map("cost_price") @db.Decimal(12, 2)
  totalPrice              Decimal          @map("total_price") @db.Decimal(12, 2)
  returnedQty             Float            @default(0) @map("returned_qty")
  baseUnitNameSnapshot    String?          @map("base_unit_name_snapshot")
  brandSnapshot           String?          @map("brand_snapshot")
  extraUnitQuantity       Float            @default(0) @map("extra_unit_quantity")
  packageNameSnapshot     String?          @map("package_name_snapshot")
  packageQuantity         Float?           @map("package_quantity")
  packagingId             Int?             @map("packaging_id")
  productNameSnapshot     String?          @map("product_name_snapshot")
  rawNameSnapshot         String?          @map("raw_name_snapshot")
  totalBaseUnits          Float?           @map("total_base_units")
  unitsPerPackageSnapshot Int?             @map("units_per_package_snapshot")
  invoice                 Invoice          @relation(fields: [invoiceId], references: [id])
  product                 Product          @relation(fields: [productId], references: [id])
  saleAllocations         SaleAllocation[]

  @@map("invoice_items")
}

model SaleAllocation {
  id            Int          @id @default(autoincrement())
  invoiceItemId Int          @map("invoice_item_id")
  batchId       Int          @map("batch_id")
  quantity      Float
  batch         ProductBatch @relation(fields: [batchId], references: [id])
  invoiceItem   InvoiceItem  @relation(fields: [invoiceItemId], references: [id])

  @@map("sale_allocations")
}

model Payment {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  invoiceId  Int?     @map("invoice_id")
  userId     Int      @map("user_id")
  amount     Decimal  @db.Decimal(12, 2)
  method     String   @default("cash")
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id])
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@map("payments")
}

model Expense {
  id          Int       @id @default(autoincrement())
  warehouseId Int       @map("warehouse_id")
  userId      Int       @map("user_id")
  category    String
  title       String
  amount      Decimal   @db.Decimal(12, 2)
  expenseDate DateTime  @map("expense_date")
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  paidAmount  Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  user        User      @relation(fields: [userId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("expenses")
}

model Return {
  id         Int      @id @default(autoincrement())
  invoiceId  Int      @map("invoice_id")
  customerId Int      @map("customer_id")
  userId     Int      @map("user_id")
  reason     String?
  totalValue Decimal  @map("total_value") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id])
  invoice    Invoice  @relation(fields: [invoiceId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@map("returns")
}

model InventoryTransaction {
  id            Int       @id @default(autoincrement())
  productId     Int       @map("product_id")
  warehouseId   Int       @map("warehouse_id")
  userId        Int       @map("user_id")
  qtyChange     Float     @map("qty_change")
  type          String
  reason        String?
  referenceId   Int?      @map("reference_id")
  costAtTime    Decimal?  @map("cost_at_time") @db.Decimal(12, 2)
  sellingAtTime Decimal?  @map("selling_at_time") @db.Decimal(12, 2)
  createdAt     DateTime  @default(now()) @map("created_at")
  product       Product   @relation(fields: [productId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("inventory_transactions")
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("settings")
}

model Reminder {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  title       String
  description String?
  dueDate     DateTime @map("due_date")
  isCompleted Boolean  @default(false) @map("is_completed")
  type        String   @default("general")
  referenceId Int?     @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id])

  @@map("reminders")
}

model rate_limit_entries {
  key           String    @id
  count         Int
  reset_at      DateTime  @db.Timestamptz(6)
  blocked_until DateTime? @db.Timestamptz(6)
}
